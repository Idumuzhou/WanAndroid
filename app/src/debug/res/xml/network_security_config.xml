<?xml version="1.0" encoding="utf-8"?>
<!-- Debug 网络安全配置，允许调试包信任用户安装的抓包证书。 -->
<network-security-config>
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
